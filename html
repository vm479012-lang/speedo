<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPEEDO – Quick Commerce</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --green:#00b853; --green-d:#008a3d; --green-l:#e6f9ee;
  --yellow:#ffd60a; --orange:#ff6b00; --purple:#7c3aed;
  --bg:#f3f5fa; --card:#fff; --text:#111; --muted:#777; --border:#eaeaea;
  --nav-h:62px;
}
body { font-family:'Nunito',sans-serif; background:var(--bg); color:var(--text); max-width:480px; margin:0 auto; min-height:100vh; overflow-x:hidden; }

/* PAGES */
.page { display:none; padding-bottom:calc(var(--nav-h) + 12px); animation:fadeIn .2s ease; }
.page.active { display:block; }
@keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:none} }

/* ── HOME HEADER ── */
.header { background:var(--green); padding:12px 16px 11px; position:sticky; top:0; z-index:50; }
.header .row1 { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
.logo { font-family:'Syne',sans-serif; font-size:24px; font-weight:800; color:#fff; letter-spacing:-.5px; }
.logo span { color:var(--yellow); }
.loc { color:rgba(255,255,255,.8); font-size:11px; font-weight:600; }
.header-icons { display:flex; gap:8px; align-items:center; }
.icon-btn {
  background:rgba(255,255,255,.2); border:none; color:#fff; width:36px; height:36px;
  border-radius:10px; cursor:pointer; font-size:18px; display:flex; align-items:center; justify-content:center; transition:.15s;
}
.icon-btn:hover { background:rgba(255,255,255,.35); }
.cart-icon-wrap { position:relative; }
.cart-badge {
  position:absolute; top:-5px; right:-5px; background:var(--orange); color:#fff;
  width:17px; height:17px; border-radius:50%; font-size:10px; font-weight:900;
  display:flex; align-items:center; justify-content:center; border:2px solid var(--green);
}
.search-bar { background:#fff; border-radius:10px; padding:9px 14px; display:flex; align-items:center; gap:8px; }
.search-bar input { border:none; outline:none; flex:1; font-size:14px; font-family:'Nunito',sans-serif; color:var(--text); background:transparent; }

/* ── SIMPLE HEADER ── */
.simple-header { background:var(--green); padding:14px 16px; display:flex; align-items:center; gap:12px; position:sticky; top:0; z-index:50; }
.simple-header h2 { font-family:'Syne',sans-serif; font-size:20px; color:#fff; font-weight:800; }
.back-btn { background:rgba(255,255,255,.2); border:none; color:#fff; width:32px; height:32px; border-radius:8px; cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }

/* ── BOTTOM NAV ── */
.bottom-nav {
  position:fixed; bottom:0; left:50%; transform:translateX(-50%);
  width:100%; max-width:480px; background:#fff; border-top:1px solid var(--border);
  display:flex; height:var(--nav-h); z-index:99; box-shadow:0 -4px 20px rgba(0,0,0,.08);
}
.nav-item { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; gap:3px; border:none; background:none; font-family:'Nunito',sans-serif; transition:.15s; }
.nav-item .nav-icon { font-size:21px; }
.nav-item .nav-label { font-size:11px; font-weight:700; color:var(--muted); }
.nav-item.active .nav-label { color:var(--green); }
.nav-item.active .nav-icon { transform:scale(1.15); }

/* ── CATEGORIES ── */
.cats { display:flex; gap:10px; padding:14px 16px; overflow-x:auto; scrollbar-width:none; }
.cats::-webkit-scrollbar { display:none; }
.cat-pill { display:flex; flex-direction:column; align-items:center; gap:4px; background:var(--card); border-radius:14px; padding:10px 14px; min-width:76px; cursor:pointer; border:2px solid transparent; box-shadow:0 2px 8px rgba(0,0,0,.06); transition:.15s; }
.cat-pill.active { border-color:var(--green); background:var(--green-l); }
.cat-pill .cat-emoji { font-size:22px; }
.cat-pill .cat-name { font-size:11px; font-weight:800; color:var(--text); }
.cat-pill.active .cat-name { color:var(--green); }

/* ── PROMO ── */
.promo-banner { margin:0 16px 4px; border-radius:16px; background:linear-gradient(135deg,#007a36,#00b853,#00d968); padding:20px; position:relative; overflow:hidden; }
.promo-banner h3 { font-family:'Syne',sans-serif; font-size:22px; color:#fff; font-weight:800; line-height:1.2; }
.promo-banner p { color:rgba(255,255,255,.85); font-size:13px; margin-top:4px; font-weight:600; }
.promo-chip { display:inline-block; background:var(--yellow); color:#000; font-weight:900; font-size:12px; border-radius:6px; padding:4px 10px; margin-top:10px; }
.promo-deco { position:absolute; right:20px; top:50%; transform:translateY(-50%); font-size:58px; opacity:.2; }

/* ── NEW USER REFERRAL BANNER (homepage) ── */
.ref-home-banner {
  margin:12px 16px 0; border-radius:14px; overflow:hidden;
  background:linear-gradient(135deg,#4f0882,#7c3aed);
  padding:14px 16px; display:flex; align-items:center; gap:12px;
}
.ref-home-banner .ref-icon { font-size:32px; flex-shrink:0; }
.ref-home-text h4 { font-size:14px; font-weight:900; color:#fff; }
.ref-home-text p { font-size:12px; color:rgba(255,255,255,.8); font-weight:600; margin-top:2px; }
.ref-home-btn { margin-left:auto; background:var(--yellow); color:#000; border:none; border-radius:8px; padding:7px 12px; font-weight:900; font-size:12px; cursor:pointer; font-family:'Nunito',sans-serif; white-space:nowrap; }

/* ── DEL CHIP ── */
.del-chip { display:flex; align-items:center; gap:8px; background:var(--card); margin:12px 16px 0; border-radius:10px; padding:9px 14px; border:1px solid var(--border); }
.del-chip p { font-size:13px; font-weight:700; color:var(--text); }
.del-chip span { color:var(--green); }

/* ── SECTION HEAD ── */
.section-head { padding:14px 16px 8px; display:flex; justify-content:space-between; align-items:center; }
.section-head h2 { font-size:17px; font-weight:900; }
.see-all { font-size:13px; color:var(--green); font-weight:700; cursor:pointer; background:none; border:none; font-family:'Nunito',sans-serif; }

/* ── PRODUCT GRID (Zepto style 3 col) ── */
.product-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:12px; padding:0 16px 16px; }
.product-card { background:var(--card); border-radius:16px; padding:12px; border:1px solid var(--border); position:relative; transition:.15s; }
.product-card:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(0,0,0,.1); }
.product-tag { position:absolute; top:10px; left:10px; background:var(--green-l); color:var(--green-d); font-size:10px; font-weight:800; border-radius:5px; padding:2px 7px; }
.product-emoji { font-size:46px; text-align:center; display:block; padding:8px 0 4px; line-height:1; }
.product-name { font-size:13px; font-weight:800; margin-bottom:2px; }
.product-qty-label { font-size:11px; color:var(--muted); margin-bottom:6px; }
.product-price-row { display:flex; align-items:baseline; gap:6px; margin-bottom:8px; }
.product-price { font-size:16px; font-weight:900; }
.product-old { font-size:11px; color:var(--muted); text-decoration:line-through; }

/* Zepto-style add controls */
.add-btn { width:100%; border:2px solid var(--green); background:#fff; color:var(--green); border-radius:10px; padding:8px; font-weight:900; font-size:14px; cursor:pointer; font-family:'Nunito',sans-serif; transition:.15s; }
.add-btn:hover { background:var(--green); color:#fff; }
.zepto-ctrl { display:flex; align-items:center; justify-content:space-between; border:2px solid var(--green); border-radius:10px; overflow:hidden; height:36px; }
.zepto-ctrl .z-btn { background:#fff; color:var(--green); border:none; width:36px; height:100%; font-size:20px; cursor:pointer; font-weight:900; font-family:'Nunito',sans-serif; display:flex; align-items:center; justify-content:center; transition:.15s; flex-shrink:0; }
.zepto-ctrl .z-btn:hover { background:var(--green-l); }
.zepto-ctrl .z-btn.minus { border-right:1.5px solid var(--green); }
.zepto-ctrl .z-btn.plus { border-left:1.5px solid var(--green); }
.zepto-ctrl .z-num { flex:1; text-align:center; font-weight:900; font-size:15px; color:var(--green); background:#fff; }

/* ── REFERRAL FLOATING PANEL ── */
.ref-panel {
  position:fixed; bottom:calc(var(--nav-h) + 10px); left:50%; transform:translateX(-50%) translateY(120px);
  width:calc(100% - 32px); max-width:448px; z-index:90;
  background:linear-gradient(135deg,#4f0882,#7c3aed,#a855f7);
  border-radius:20px; padding:16px 18px; box-shadow:0 8px 32px rgba(124,58,237,.45);
  display:flex; gap:14px; align-items:center;
  transition:transform .4s cubic-bezier(.34,1.56,.64,1), opacity .3s;
  opacity:0; pointer-events:none;
}
.ref-panel.visible { transform:translateX(-50%) translateY(0); opacity:1; pointer-events:all; }
.ref-panel .rp-icon { font-size:36px; flex-shrink:0; }
.ref-panel .rp-text h4 { font-size:14px; font-weight:900; color:#fff; }
.ref-panel .rp-text p { font-size:12px; color:rgba(255,255,255,.8); font-weight:600; margin-top:2px; }
.ref-panel .rp-btn { margin-left:auto; background:var(--yellow); color:#000; border:none; border-radius:10px; padding:9px 14px; font-weight:900; font-size:13px; cursor:pointer; font-family:'Nunito',sans-serif; white-space:nowrap; flex-shrink:0; }
.ref-panel .rp-close { position:absolute; top:8px; right:10px; background:none; border:none; color:rgba(255,255,255,.6); font-size:16px; cursor:pointer; line-height:1; }

/* ── CART PAGE (Zepto style) ── */
.cart-empty { padding:60px 20px; text-align:center; }
.cart-empty .big-e { font-size:64px; display:block; margin-bottom:16px; }
.cart-empty p { font-size:16px; color:var(--muted); font-weight:700; }

/* Cart item Zepto style */
.zepto-cart-item {
  background:var(--card); margin:0 16px 10px; border-radius:16px;
  padding:14px 14px; border:1px solid var(--border); display:flex; align-items:center; gap:12px;
}
.zci-emoji { font-size:36px; flex-shrink:0; }
.zci-info { flex:1; min-width:0; }
.zci-name { font-size:14px; font-weight:800; }
.zci-unit { font-size:11px; color:var(--muted); }
.zci-price { font-size:14px; font-weight:900; color:var(--text); margin-top:2px; }
.zci-ctrl { display:flex; align-items:center; gap:0; border:2px solid var(--green); border-radius:10px; overflow:hidden; flex-shrink:0; }
.zci-ctrl button { background:#fff; color:var(--green); border:none; width:32px; height:32px; font-size:18px; font-weight:900; cursor:pointer; font-family:'Nunito',sans-serif; display:flex; align-items:center; justify-content:center; }
.zci-ctrl button:hover { background:var(--green-l); }
.zci-ctrl button.minus { border-right:1.5px solid var(--green); }
.zci-ctrl button.plus { border-left:1.5px solid var(--green); }
.zci-ctrl .zci-num { width:28px; text-align:center; font-weight:900; font-size:14px; color:var(--green); background:#fff; }

.bill-card { background:var(--card); margin:0 16px 12px; border-radius:16px; padding:16px; border:1px solid var(--border); }
.bill-card h3 { font-size:16px; font-weight:900; margin-bottom:12px; }
.bill-row { display:flex; justify-content:space-between; font-size:14px; margin-bottom:8px; color:var(--text); }
.bill-row.green { color:var(--green); font-weight:800; }
.bill-row.total { font-weight:900; font-size:16px; padding-top:10px; border-top:1px dashed var(--border); margin-top:4px; }

.reward-strip { background:linear-gradient(135deg,#007a36,#00b853); margin:0 16px 12px; border-radius:14px; padding:14px; color:#fff; }
.reward-strip strong { font-size:15px; font-weight:900; display:block; }
.reward-strip p { font-size:13px; margin-top:3px; opacity:.9; font-weight:600; }

.ref-strip { background:linear-gradient(135deg,#4f0882,#7c3aed); margin:0 16px 12px; border-radius:14px; padding:14px; color:#fff; display:flex; align-items:center; gap:12px; }
.ref-strip .rs-icon { font-size:28px; }
.ref-strip strong { font-size:14px; font-weight:900; display:block; }
.ref-strip p { font-size:12px; margin-top:2px; opacity:.85; font-weight:600; }
.ref-strip .rs-btn { margin-left:auto; background:var(--yellow); color:#000; border:none; border-radius:8px; padding:8px 12px; font-weight:900; font-size:12px; cursor:pointer; font-family:'Nunito',sans-serif; flex-shrink:0; white-space:nowrap; }

.checkout-btn-full { background:var(--green); color:#fff; border:none; width:calc(100% - 32px); margin:0 16px 10px; padding:16px; border-radius:14px; font-size:17px; font-weight:900; cursor:pointer; font-family:'Nunito',sans-serif; transition:.15s; display:flex; justify-content:space-between; align-items:center; }
.checkout-btn-full:hover { background:var(--green-d); }
.cod-btn { background:#fff; color:var(--green); border:2px solid var(--green); width:calc(100% - 32px); margin:0 16px 10px; padding:14px; border-radius:14px; font-size:15px; font-weight:900; cursor:pointer; font-family:'Nunito',sans-serif; }

/* ── DISCOUNTS / ROADMAP PAGE ── */
.discount-hero { background:linear-gradient(135deg,#111,#1a1a2e); margin:16px; border-radius:20px; padding:24px; color:#fff; position:relative; overflow:hidden; }
.discount-hero::before { content:''; position:absolute; inset:0; background:radial-gradient(circle at 80% 50%,rgba(0,184,83,.3),transparent 60%); }
.discount-hero h2 { font-family:'Syne',sans-serif; font-size:26px; font-weight:800; position:relative; }
.discount-hero p { color:rgba(255,255,255,.7); font-size:13px; margin-top:6px; position:relative; font-weight:600; }
.progress-ring { position:absolute; right:20px; top:50%; transform:translateY(-50%); text-align:center; }
.ring-num { font-family:'Syne',sans-serif; font-size:28px; font-weight:800; color:var(--yellow); }
.ring-label { font-size:11px; color:rgba(255,255,255,.6); font-weight:600; }

.road-card { background:var(--card); margin:0 16px 10px; border-radius:16px; border:1px solid var(--border); overflow:hidden; }
.road-card-header { padding:14px 16px; display:flex; align-items:center; gap:12px; }
.road-icon { width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
.road-title { font-size:15px; font-weight:900; }
.road-sub { font-size:12px; color:var(--muted); font-weight:600; }
.road-pct { margin-left:auto; font-family:'Syne',sans-serif; font-size:22px; font-weight:800; color:var(--green); }
.road-bar { height:6px; background:var(--border); }
.road-bar-fill { height:100%; background:var(--green); border-radius:3px; transition:width .6s ease; }
.road-steps { padding:14px 16px; display:flex; flex-direction:column; gap:10px; }
.road-step { display:flex; align-items:center; gap:12px; }
.step-dot { width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:900; flex-shrink:0; }
.step-dot.done { background:var(--green); color:#fff; }
.step-dot.current { background:var(--yellow); color:#000; }
.step-dot.locked { background:var(--border); color:var(--muted); }
.step-info { flex:1; }
.step-name { font-size:13px; font-weight:800; }
.step-range { font-size:11px; color:var(--muted); }
.step-badge { background:var(--green-l); color:var(--green-d); border-radius:6px; padding:3px 9px; font-size:12px; font-weight:800; }

/* LOCKED ROADMAP state */
.roadmap-locked { background:var(--card); margin:0 16px 12px; border-radius:16px; border:2px dashed #d1b3f7; padding:24px; text-align:center; }
.roadmap-locked .lock-icon { font-size:48px; display:block; margin-bottom:12px; }
.roadmap-locked h3 { font-size:18px; font-weight:900; margin-bottom:6px; }
.roadmap-locked p { font-size:13px; color:var(--muted); font-weight:600; line-height:1.5; }

.medal-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin:0 16px 16px; }
.medal-card { background:var(--card); border-radius:14px; border:1px solid var(--border); padding:16px 10px; text-align:center; }
.medal-icon { font-size:36px; display:block; margin-bottom:8px; filter:grayscale(100%) brightness(.8); }
.medal-icon.unlocked { filter:none; }
.medal-name { font-size:12px; font-weight:800; color:var(--muted); }
.medal-name.unlocked { color:var(--text); }
.medal-req { font-size:10px; color:var(--muted); margin-top:3px; }

/* ── REFERRAL TAB (inside Discounts page) ── */
.ref-tab-card { background:var(--card); margin:0 16px 12px; border-radius:16px; border:1px solid var(--border); overflow:hidden; }
.ref-tab-header { background:linear-gradient(135deg,#4f0882,#7c3aed); padding:20px; }
.ref-tab-header h3 { font-family:'Syne',sans-serif; font-size:20px; color:#fff; font-weight:800; }
.ref-tab-header p { color:rgba(255,255,255,.8); font-size:13px; font-weight:600; margin-top:4px; }
.ref-stats { display:flex; gap:0; border-bottom:1px solid var(--border); }
.ref-stat { flex:1; text-align:center; padding:14px 8px; border-right:1px solid var(--border); }
.ref-stat:last-child { border-right:none; }
.ref-stat-num { font-family:'Syne',sans-serif; font-size:24px; font-weight:800; color:var(--purple); }
.ref-stat-label { font-size:11px; color:var(--muted); font-weight:700; margin-top:2px; }
.ref-code-box { margin:16px; background:#f8f4ff; border:2px dashed #a855f7; border-radius:12px; padding:14px; display:flex; align-items:center; justify-content:space-between; }
.ref-code { font-family:'Syne',sans-serif; font-size:22px; font-weight:800; color:var(--purple); letter-spacing:2px; }
.copy-btn { background:var(--purple); color:#fff; border:none; border-radius:8px; padding:8px 16px; font-weight:900; font-size:13px; cursor:pointer; font-family:'Nunito',sans-serif; }

.ref-steps-list { padding:0 16px 16px; display:flex; flex-direction:column; gap:0; }
.ref-step-row { display:flex; gap:12px; align-items:flex-start; padding:12px 0; border-bottom:1px solid var(--border); }
.ref-step-row:last-child { border-bottom:none; }
.ref-step-num { width:32px; height:32px; border-radius:50%; background:var(--purple); color:#fff; font-weight:900; font-size:14px; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:2px; }
.ref-step-title { font-size:14px; font-weight:800; }
.ref-step-desc { font-size:12px; color:var(--muted); font-weight:600; margin-top:2px; }

/* Progress towards roadmap unlock */
.ref-progress-bar-wrap { margin:0 16px 12px; background:var(--card); border-radius:14px; border:1px solid var(--border); padding:16px; }
.ref-progress-bar-wrap h4 { font-size:14px; font-weight:900; margin-bottom:10px; }
.prog-track { background:var(--border); border-radius:6px; height:10px; overflow:hidden; margin-bottom:8px; }
.prog-fill { height:100%; border-radius:6px; background:linear-gradient(90deg,#7c3aed,#a855f7); transition:width .5s; }
.prog-label { font-size:13px; font-weight:700; color:var(--purple); }

/* ── ACCOUNT PAGE ── */
.account-header-card { background:linear-gradient(135deg,var(--green),#007a36); margin:16px; border-radius:20px; padding:24px; color:#fff; display:flex; gap:16px; align-items:center; }
.avatar { width:60px; height:60px; border-radius:50%; background:rgba(255,255,255,.2); display:flex; align-items:center; justify-content:center; font-size:28px; flex-shrink:0; }
.account-name { font-family:'Syne',sans-serif; font-size:20px; font-weight:800; }
.account-sub { font-size:13px; opacity:.8; font-weight:600; margin-top:2px; }
.account-stats { display:flex; gap:20px; margin-top:12px; }
.stat-box { text-align:center; }
.stat-num { font-family:'Syne',sans-serif; font-size:22px; font-weight:800; color:var(--yellow); }
.stat-label { font-size:11px; opacity:.7; font-weight:600; }

.menu-group { margin:0 16px 12px; background:var(--card); border-radius:16px; border:1px solid var(--border); overflow:hidden; }
.menu-item { display:flex; align-items:center; gap:14px; padding:15px 16px; border-bottom:1px solid var(--border); cursor:pointer; transition:.15s; }
.menu-item:last-child { border-bottom:none; }
.menu-item:hover { background:var(--bg); }
.menu-item-icon { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
.menu-item-text { flex:1; font-size:14px; font-weight:800; }
.menu-item-arrow { color:var(--muted); font-size:14px; }
.menu-item-badge { background:var(--green-l); color:var(--green-d); font-size:11px; font-weight:800; padding:2px 8px; border-radius:6px; }
.menu-item-badge.purple { background:#f3e8ff; color:#6d28d9; }

/* ── SUCCESS MODAL ── */
.modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.55); z-index:200; align-items:center; justify-content:center; }
.modal-overlay.open { display:flex; }
.modal-box { background:#fff; border-radius:24px; padding:32px 24px; text-align:center; width:calc(100% - 48px); max-width:360px; animation:popIn .3s cubic-bezier(.34,1.56,.64,1); }
@keyframes popIn { from{opacity:0;transform:scale(.7)} to{opacity:1;transform:scale(1)} }
.modal-icon { font-size:72px; display:block; margin-bottom:16px; }
.modal-box h2 { font-family:'Syne',sans-serif; font-size:24px; font-weight:800; margin-bottom:8px; }
.modal-box p { color:var(--muted); font-size:14px; font-weight:600; margin-bottom:20px; }
.modal-reward { background:var(--green-l); border-radius:12px; padding:14px; margin-bottom:20px; }
.modal-reward p { color:var(--green-d); font-weight:800; font-size:15px; margin:0; }
.modal-btn { background:var(--green); color:#fff; border:none; width:100%; padding:14px; border-radius:12px; font-size:16px; font-weight:900; cursor:pointer; font-family:'Nunito',sans-serif; }

/* ── TOAST ── */
.toast { position:fixed; bottom:80px; left:50%; transform:translateX(-50%) translateY(20px); background:#111; color:#fff; padding:10px 20px; border-radius:20px; font-size:13px; font-weight:700; opacity:0; transition:all .3s; z-index:300; pointer-events:none; white-space:nowrap; }
.toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
</style>
</head>
<body>

<!-- ══════════ HOME ══════════ -->
<div class="page active" id="page-home">
  <div class="header">
    <div class="row1">
      <div>
        <div class="logo">⚡<span>SPEEDO</span></div>
        <div class="loc">📍 Delivery in <strong style="color:#fff">8 mins</strong></div>
      </div>
      <div class="header-icons">
        <button class="icon-btn" onclick="goPage('account')" title="Account">👤</button>
        <div class="cart-icon-wrap">
          <button class="icon-btn" onclick="goPage('cart')" title="Cart" style="background:var(--yellow);color:#000;font-size:20px;">🛒</button>
          <div class="cart-badge" id="home-badge">0</div>
        </div>
      </div>
    </div>
    <div class="search-bar">
      <span style="color:var(--muted);font-size:16px">🔍</span>
      <input placeholder="Search milk, fruits, ice cream…" oninput="filterProducts(this.value)" id="search-input" />
    </div>
  </div>

  <!-- new-user referral banner (shows only if no orders yet) -->
  <div class="ref-home-banner" id="ref-home-banner" style="display:none">
    <div class="ref-icon">🎁</div>
    <div class="ref-home-text">
      <h4>Refer friends &amp; earn ₹50 off!</h4>
      <p>Your friend gets ₹50 off their first order (≥₹99)</p>
    </div>
    <button class="ref-home-btn" onclick="goPage('discounts');setTimeout(()=>showReferralTab(),100)">Share</button>
  </div>

  <div class="cats" id="cat-tabs"></div>

  <div class="promo-banner">
    <h3>50% OFF<br>First Order</h3>
    <p>Max ₹150 · Auto applied</p>
    <div class="promo-chip">AUTO APPLIED</div>
    <div class="promo-deco">🛒</div>
  </div>

  <div class="del-chip">
    <p>⚡ FREE delivery on orders above <span>₹99</span> &nbsp;·&nbsp; 8-min delivery promise</p>
  </div>

  <div class="section-head">
    <h2 id="section-title">🔥 Popular near you</h2>
    <button class="see-all" onclick="showAll()">See all</button>
  </div>

  <div class="product-grid" id="product-grid"></div>
</div>

<!-- ══════════ CART ══════════ -->
<div class="page" id="page-cart">
  <div class="simple-header">
    <button class="back-btn" onclick="goPage('home')">←</button>
    <h2>🛒 My Cart</h2>
  </div>
  <div id="cart-content" style="padding-top:12px"></div>
</div>

<!-- ══════════ DISCOUNTS / ROADMAP ══════════ -->
<div class="page" id="page-discounts">
  <div class="simple-header">
    <h2>🎯 Offers &amp; Roadmap</h2>
  </div>
  <!-- Sub-tabs -->
  <div style="display:flex;background:#fff;border-bottom:1px solid var(--border);position:sticky;top:54px;z-index:40">
    <button class="subtab active" id="stab-road" onclick="switchSubTab('road')" style="flex:1;padding:12px;border:none;background:none;font-family:'Nunito',sans-serif;font-weight:900;font-size:14px;cursor:pointer;border-bottom:3px solid var(--green);color:var(--green)">🏆 Roadmap</button>
    <button class="subtab" id="stab-ref" onclick="switchSubTab('ref')" style="flex:1;padding:12px;border:none;background:none;font-family:'Nunito',sans-serif;font-weight:900;font-size:14px;cursor:pointer;border-bottom:3px solid transparent;color:var(--muted)">🎁 Referral</button>
  </div>
  <div id="sub-road" class="sub-panel"></div>
  <div id="sub-ref" class="sub-panel" style="display:none"></div>
</div>

<!-- ══════════ ACCOUNT ══════════ -->
<div class="page" id="page-account">
  <div id="account-content"></div>
</div>

<!-- ══════════ BOTTOM NAV ══════════ -->
<nav class="bottom-nav">
  <button class="nav-item active" onclick="goPage('home')" id="nav-home"><div class="nav-icon">🏠</div><div class="nav-label">Home</div></button>
  <button class="nav-item" onclick="goPage('discounts')" id="nav-discounts"><div class="nav-icon">🎯</div><div class="nav-label">Offers</div></button>
  <button class="nav-item" onclick="goPage('cart')" id="nav-cart"><div class="nav-icon">🛒</div><div class="nav-label">Cart</div></button>
  <button class="nav-item" onclick="goPage('account')" id="nav-account"><div class="nav-icon">👤</div><div class="nav-label">Account</div></button>
</nav>

<!-- ══════════ REFERRAL FLOATING PANEL ══════════ -->
<div class="ref-panel" id="ref-panel">
  <button class="rp-close" onclick="dismissRefPanel()">✕</button>
  <div class="rp-icon">🎁</div>
  <div class="rp-text">
    <h4>Refer a friend &amp; get ₹50 off!</h4>
    <p>Your friend saves ₹50 on their first order ≥₹99</p>
  </div>
  <button class="rp-btn" onclick="goPage('discounts');setTimeout(()=>showReferralTab(),100);dismissRefPanel()">Refer Now</button>
</div>

<!-- ══════════ ORDER SUCCESS MODAL ══════════ -->
<div class="modal-overlay" id="modal">
  <div class="modal-box">
    <span class="modal-icon" id="modal-icon">🎉</span>
    <h2 id="modal-title">Order Placed!</h2>
    <p id="modal-msg">Your order is on the way.</p>
    <div class="modal-reward"><p id="modal-reward-text"></p></div>
    <button class="modal-btn" onclick="closeModal()">🏠 Back to Home</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ─────────────────────────────
// DATA
// ─────────────────────────────
const PRODUCTS = [
  {id:1,name:"Amul Milk",qty:"500 ml",price:28,old:35,emoji:"🥛",cat:"Dairy",tag:"Bestseller"},
  {id:2,name:"Farm Eggs",qty:"12 pcs",price:89,old:110,emoji:"🥚",cat:"Dairy",tag:"Organic"},
  {id:3,name:"Butter",qty:"100 g",price:54,old:60,emoji:"🧈",cat:"Dairy"},
  {id:4,name:"Cheddar Cheese",qty:"200 g",price:149,old:180,emoji:"🧀",cat:"Dairy"},
  {id:5,name:"Bread Loaf",qty:"400 g",price:45,old:55,emoji:"🍞",cat:"Bakery",tag:"Fresh"},
  {id:6,name:"Croissant",qty:"4 pcs",price:79,old:null,emoji:"🥐",cat:"Bakery"},
  {id:7,name:"Banana",qty:"6 pcs",price:39,old:null,emoji:"🍌",cat:"Fruits",tag:"Fresh"},
  {id:8,name:"Royal Apple",qty:"4 pcs",price:129,old:160,emoji:"🍎",cat:"Fruits"},
  {id:9,name:"Mango",qty:"2 pcs",price:89,old:110,emoji:"🥭",cat:"Fruits",tag:"Season"},
  {id:10,name:"Tomato",qty:"500 g",price:25,old:null,emoji:"🍅",cat:"Veggies",tag:"Fresh"},
  {id:11,name:"Onion",qty:"1 kg",price:42,old:null,emoji:"🧅",cat:"Veggies"},
  {id:12,name:"Broccoli",qty:"300 g",price:59,old:null,emoji:"🥦",cat:"Veggies"},
  {id:13,name:"Vanilla Ice Cream",qty:"500 ml",price:140,old:180,emoji:"🍦",cat:"Frozen",tag:"20% off"},
  {id:14,name:"Frozen Peas",qty:"400 g",price:65,old:null,emoji:"🫛",cat:"Frozen"},
  {id:15,name:"Lay's Chips",qty:"90 g",price:30,old:35,emoji:"🥔",cat:"Snacks"},
  {id:16,name:"Dark Chocolate",qty:"80 g",price:65,old:null,emoji:"🍫",cat:"Snacks"},
  {id:17,name:"Orange Juice",qty:"1 L",price:99,old:120,emoji:"🍊",cat:"Drinks"},
  {id:18,name:"Green Tea",qty:"25 bags",price:79,old:95,emoji:"🍵",cat:"Drinks"},
];
const CATS = ["All","Dairy","Bakery","Fruits","Veggies","Frozen","Snacks","Drinks"];

// ─────────────────────────────
// STATE
// ─────────────────────────────
let cart = JSON.parse(localStorage.getItem("sp-cart")) || {};
let user = JSON.parse(localStorage.getItem("sp-user")) || {
  name:"Mahesh Kumar", bonusUsed:false, roadmapOrders:0, totalOrders:0,
  wallet:0, referralCode:"MAHESH50", referralsMade:0, roadmapUnlocked:false,
  refPanelDismissed:false
};
let activeCat = "All";
let refPanelVisible = false;

function saveCart(){ localStorage.setItem("sp-cart",JSON.stringify(cart)); }
function saveUser(){ localStorage.setItem("sp-user",JSON.stringify(user)); }

// ─────────────────────────────
// NAVIGATION
// ─────────────────────────────
function goPage(p){
  document.querySelectorAll(".page").forEach(x=>x.classList.remove("active"));
  document.querySelectorAll(".nav-item").forEach(x=>x.classList.remove("active"));
  document.getElementById("page-"+p).classList.add("active");
  document.getElementById("nav-"+p).classList.add("active");
  if(p==="cart") renderCartPage();
  if(p==="discounts"){ renderRoadmapTab(); renderReferralTab(); }
  if(p==="account") renderAccountPage();
}

// ─────────────────────────────
// CATEGORIES
// ─────────────────────────────
function catEmoji(c){ return {All:"🔥",Dairy:"🥛",Bakery:"🍞",Fruits:"🍎",Veggies:"🥦",Frozen:"🧊",Snacks:"🍟",Drinks:"🥤"}[c]||"🏷"; }
function renderCategories(){
  document.getElementById("cat-tabs").innerHTML = CATS.map(c=>
    `<div class="cat-pill ${c===activeCat?"active":""}" onclick="setCategory('${c}')">
      <div class="cat-emoji">${catEmoji(c)}</div>
      <div class="cat-name">${c}</div>
    </div>`
  ).join("");
}
function setCategory(cat){
  activeCat=cat;
  renderCategories();
  document.getElementById("section-title").textContent = cat==="All"?"🔥 Popular near you":`${catEmoji(cat)} ${cat}`;
  renderProducts(PRODUCTS.filter(p=>cat==="All"||p.cat===cat));
}
function showAll(){ setCategory("All"); document.getElementById("search-input").value=""; }
function filterProducts(q){
  renderProducts(PRODUCTS.filter(p=>p.name.toLowerCase().includes(q.toLowerCase())||p.cat.toLowerCase().includes(q.toLowerCase())));
  document.getElementById("section-title").textContent = q?`🔍 "${q}"`:"🔥 Popular near you";
}

// ─────────────────────────────
// PRODUCTS (Zepto qty controls)
// ─────────────────────────────
function renderProducts(list){
  document.getElementById("product-grid").innerHTML = list.map(p=>{
    const c = cart[p.id]||0;
    return `<div class="product-card" id="pc-${p.id}">
      ${p.tag?`<div class="product-tag">${p.tag}</div>`:""}
      <span class="product-emoji">${p.emoji}</span>
      <div class="product-name">${p.name}</div>
      <div class="product-qty-label">${p.qty}</div>
      <div class="product-price-row">
        <div class="product-price">₹${p.price}</div>
        ${p.old?`<div class="product-old">₹${p.old}</div>`:""}
      </div>
      ${c===0
        ? `<button class="add-btn" onclick="addToCart(${p.id})">+ Add</button>`
        : `<div class="zepto-ctrl">
            <button class="z-btn minus" onclick="removeFromCart(${p.id})">−</button>
            <span class="z-num">${c}</span>
            <button class="z-btn plus" onclick="addToCart(${p.id})">+</button>
           </div>`}
    </div>`;
  }).join("");
}

function cartSubtotal(){
  return Object.keys(cart).reduce((s,id)=>{
    const p=PRODUCTS.find(x=>x.id==id); return s+(p?p.price*cart[id]:0);
  },0);
}

function addToCart(id){
  cart[id]=(cart[id]||0)+1;
  saveCart(); updateBadge();
  renderProducts(PRODUCTS.filter(p=>activeCat==="All"||p.cat===activeCat));
  checkRefPanel();
  showToast("Added to cart 🛒");
}
function removeFromCart(id){
  if(cart[id]>1) cart[id]--; else delete cart[id];
  saveCart(); updateBadge();
  renderProducts(PRODUCTS.filter(p=>activeCat==="All"||p.cat===activeCat));
  checkRefPanel();
}
function updateBadge(){
  const t=Object.values(cart).reduce((s,c)=>s+c,0);
  document.getElementById("home-badge").textContent=t;
}

// ─────────────────────────────
// REFERRAL FLOATING PANEL
// ─────────────────────────────
function checkRefPanel(){
  const sub = cartSubtotal();
  const panel = document.getElementById("ref-panel");
  if(sub >= 99 && !user.refPanelDismissed && !refPanelVisible){
    panel.classList.add("visible");
    refPanelVisible = true;
  } else if(sub < 99 && refPanelVisible){
    panel.classList.remove("visible");
    refPanelVisible = false;
  }
}
function dismissRefPanel(){
  document.getElementById("ref-panel").classList.remove("visible");
  refPanelVisible = false;
  user.refPanelDismissed = true;
  saveUser();
}

// ─────────────────────────────
// CART PAGE (Zepto style)
// ─────────────────────────────
function renderCartPage(){
  const keys = Object.keys(cart);
  const el = document.getElementById("cart-content");
  if(keys.length===0){
    el.innerHTML=`<div class="cart-empty"><span class="big-e">🛒</span><p>Your cart is empty</p>
      <button onclick="goPage('home')" style="margin-top:16px;background:var(--green);color:#fff;border:none;padding:12px 28px;border-radius:12px;font-size:15px;font-weight:900;cursor:pointer;font-family:'Nunito',sans-serif">Shop now</button></div>`;
    return;
  }
  let subtotal=0;
  let itemsHTML = keys.map(id=>{
    const p=PRODUCTS.find(x=>x.id==id); if(!p)return "";
    const line=p.price*cart[id]; subtotal+=line;
    return `<div class="zepto-cart-item">
      <div class="zci-emoji">${p.emoji}</div>
      <div class="zci-info">
        <div class="zci-name">${p.name}</div>
        <div class="zci-unit">${p.qty}</div>
        <div class="zci-price">₹${line}</div>
      </div>
      <div class="zci-ctrl">
        <button class="minus" onclick="cartRemove(${p.id})">−</button>
        <span class="zci-num">${cart[id]}</span>
        <button class="plus" onclick="cartAdd(${p.id})">+</button>
      </div>
    </div>`;
  }).join("");

  const delivery = subtotal>=99?0:30;
  let discount=0, discMsg="", rewardHTML="", refHTML="";

  // referral strip if cart ≥ 99 and roadmap not yet unlocked
  if(subtotal>=99 && !user.roadmapUnlocked){
    refHTML=`<div class="ref-strip">
      <div class="rs-icon">🎁</div>
      <div><strong>Refer a friend → get ₹50 off!</strong><p>Your friend saves ₹50 when they order ≥₹99</p></div>
      <button class="rs-btn" onclick="goPage('discounts');setTimeout(()=>showReferralTab(),100)">Share Code</button>
    </div>`;
  }

  // discount logic
  if(!user.bonusUsed && subtotal>=199){
    discount=Math.min(subtotal*.5,150);
    discMsg="🎉 50% First Order Bonus (max ₹150)";
    rewardHTML=`<div class="reward-strip"><strong>🎁 First Order Bonus Applied!</strong><p>You're saving ₹${discount.toFixed(0)} on this order.</p></div>`;
  } else if(user.roadmapUnlocked && user.bonusUsed && subtotal>=199){
    const ord=user.roadmapOrders+1;
    let pct=0;
    if(ord<=5)pct=30; else if(ord<=10)pct=40; else if(ord<=15)pct=50;
    if(pct>0){ discount=subtotal*pct/100; discMsg=`🏆 Roadmap ${pct}% OFF (Order #${ord})`; rewardHTML=`<div class="reward-strip"><strong>🏆 Roadmap Discount: ${pct}% OFF</strong><p>You saved ₹${discount.toFixed(0)} on this order!</p></div>`; }
  } else if(!user.bonusUsed && subtotal<199 && subtotal>0){
    rewardHTML=`<div class="reward-strip" style="background:linear-gradient(135deg,#555,#333)"><strong>💡 Add ₹${199-subtotal} more</strong><p>Unlock 50% first order bonus!</p></div>`;
  }

  const final=subtotal-discount+delivery;
  el.innerHTML=`${itemsHTML}${refHTML}${rewardHTML}
    <div class="bill-card">
      <h3>Bill Details</h3>
      <div class="bill-row"><span>Item total</span><span>₹${subtotal}</span></div>
      <div class="bill-row ${delivery===0?"green":""}"><span>Delivery fee</span><span>${delivery===0?"FREE ✓":"₹"+delivery}</span></div>
      ${discount>0?`<div class="bill-row green"><span>${discMsg}</span><span>−₹${discount.toFixed(0)}</span></div>`:""}
      <div class="bill-row total"><span>To Pay</span><span>₹${final.toFixed(0)}</span></div>
    </div>
    <button class="checkout-btn-full" onclick="placeOrder()"><span>Proceed to Pay</span><span>₹${final.toFixed(0)} →</span></button>
    <button class="cod-btn" onclick="placeOrder()">📦 Cash on Delivery</button>`;
}

function cartAdd(id){ cart[id]=(cart[id]||0)+1; saveCart(); updateBadge(); renderCartPage(); checkRefPanel(); }
function cartRemove(id){ if(cart[id]>1)cart[id]--; else delete cart[id]; saveCart(); updateBadge(); renderCartPage(); checkRefPanel(); }

// ─────────────────────────────
// PLACE ORDER
// ─────────────────────────────
function placeOrder(){
  const keys=Object.keys(cart);
  if(keys.length===0){showToast("Cart is empty!");return;}
  let subtotal=cartSubtotal();
  let discount=0, rewardText="", medal="";

  if(!user.bonusUsed && subtotal>=199){
    discount=Math.min(subtotal*.5,150);
    user.bonusUsed=true;
    rewardText="🎁 First Order Bonus used! Refer a friend to unlock your Rewards Roadmap.";
  } else if(user.roadmapUnlocked && user.bonusUsed){
    user.roadmapOrders++;
    const ord=user.roadmapOrders;
    let pct=0;
    if(ord<=5)pct=30; else if(ord<=10)pct=40; else if(ord<=15)pct=50;
    if(subtotal>=199&&pct>0) discount=subtotal*pct/100;
    if(ord===5){rewardText="🥉 Bronze Medal unlocked! Next: 40% off at 6 orders.";medal="bronze";}
    else if(ord===10){rewardText="🥈 Silver Medal unlocked! Next: 50% off incoming!";medal="silver";}
    else if(ord===15){rewardText="🏅 Gold Medal unlocked! You've mastered the roadmap!";medal="gold";}
    else{rewardText=`Order #${ord} complete. Keep going for bigger discounts!`;}
  } else {
    rewardText="Refer a friend to unlock your Rewards Roadmap with 30–50% discounts!";
  }

  user.totalOrders++;
  user.wallet+=Math.floor(subtotal*.02);
  saveUser();
  cart={}; saveCart(); updateBadge();
  refPanelVisible=false;
  document.getElementById("ref-panel").classList.remove("visible");

  document.getElementById("modal-title").textContent="Order Placed! 🚀";
  document.getElementById("modal-msg").textContent="Arriving in 8 minutes. Track it live.";
  document.getElementById("modal-reward-text").textContent=rewardText;
  document.getElementById("modal-icon").textContent=medal==="gold"?"🏅":medal==="silver"?"🥈":medal==="bronze"?"🥉":"🎉";
  document.getElementById("modal").classList.add("open");
}

// Simulate: referred user places qualifying order → unlock roadmap
function simulateReferralSuccess(){
  if(!user.roadmapUnlocked){
    user.roadmapUnlocked=true;
    user.referralsMade=(user.referralsMade||0)+1;
    saveUser();
    renderReferralTab();
    showToast("🎉 Referral successful! Roadmap unlocked!");
  }
}

function closeModal(){
  document.getElementById("modal").classList.remove("open");
  goPage("home");
}

// ─────────────────────────────
// DISCOUNTS PAGE – SUB TABS
// ─────────────────────────────
function switchSubTab(tab){
  ["road","ref"].forEach(t=>{
    document.getElementById("sub-"+t).style.display = t===tab?"block":"none";
    const btn=document.getElementById("stab-"+t);
    btn.style.borderBottomColor = t===tab?"var(--green)":"transparent";
    btn.style.color = t===tab?"var(--green)":"var(--muted)";
  });
}
function showReferralTab(){ switchSubTab("ref"); }

function renderRoadmapTab(){
  const ord=user.roadmapOrders, bonusDone=user.bonusUsed, unlocked=user.roadmapUnlocked;
  const steps=[
    {label:"Bonus Order",range:"New users · first order",pct:50,special:true},
    {label:"Bronze Tier",range:"Orders 1–5",pct:30},
    {label:"Silver Tier",range:"Orders 6–10",pct:40},
    {label:"Gold Tier",range:"Orders 11–15",pct:50},
  ];
  let currentStep=0;
  if(!bonusDone) currentStep=0;
  else if(ord<5) currentStep=1;
  else if(ord<10) currentStep=2;
  else if(ord<15) currentStep=3;
  else currentStep=4;

  const stepsHTML=steps.map((s,i)=>{
    let dc="locked",dc2="🔒";
    if(i<currentStep){dc="done";dc2="✓";}
    else if(i===currentStep){dc="current";dc2=(i+1)+"";}
    return `<div class="road-step">
      <div class="step-dot ${dc}">${dc2}</div>
      <div class="step-info"><div class="step-name">${s.special?"🎁 ":""}${s.label}</div><div class="step-range">${s.range}</div></div>
      <div class="step-badge">${s.pct}% OFF</div>
    </div>`;
  }).join("");

  const barW=bonusDone?Math.min((ord/15)*100,100):0;

  const roadLocked=!unlocked?`<div class="roadmap-locked">
    <span class="lock-icon">🔒</span>
    <h3>Roadmap Locked</h3>
    <p>Refer one friend who places an order ≥₹99 to unlock your full rewards roadmap with 30%, 40% &amp; 50% discounts + medals &amp; cashback.</p>
    <button onclick="switchSubTab('ref')" style="margin-top:14px;background:var(--purple);color:#fff;border:none;border-radius:10px;padding:10px 22px;font-weight:900;font-size:14px;cursor:pointer;font-family:'Nunito',sans-serif">Go to Referral →</button>
  </div>`:"";

  document.getElementById("sub-road").innerHTML=`
    <div class="discount-hero">
      <h2>Rewards<br>Roadmap</h2>
      <p>${unlocked?"Orders above ₹199 get discounts":"Refer a friend to unlock!"}</p>
      <div class="progress-ring"><div class="ring-num">${ord}</div><div class="ring-label">Orders</div></div>
    </div>
    ${roadLocked}
    ${unlocked?`
    <div style="margin:0 16px 12px">
      <div style="font-size:12px;font-weight:700;color:var(--muted);margin-bottom:6px">ROADMAP PROGRESS</div>
      <div style="background:var(--card);border-radius:12px;border:1px solid var(--border);padding:14px">
